#include <stdio.h>
#include <stdlib.h>
#include <time.h>
int linearSearch(int arr[], int n, int key) {
    for (int i = 0; i < n; i++) {
        if (arr[i] == key)
            return i;
    }
    return -1;
}
int binarySearch(int arr[], int n, int key) {
    int low = 0, high = n - 1;
    while (low <= high) {
        int mid = (low + high) / 2;
        if (arr[mid] == key)
            return mid;
        if (arr[mid] < key)
            low = mid + 1;
        else
            high = mid - 1;
    }
    return -1;
}
int main() {
    int sizes[] = {10000, 50000, 100000, 500000, 1000000};
    int nSizes = 5;
    for (int s = 0; s < nSizes; s++) {
        int n = sizes[s];
        int *arr = (int *)malloc(n * sizeof(int));
        for (int i = 0; i < n; i++)
            arr[i] = i + 1;   
        int key = n;          
        clock_t start, end;
        start = clock();
        linearSearch(arr, n, key);
        end = clock();
        double linearTime =
            (double)(end - start) / CLOCKS_PER_SEC;
        start = clock();
        binarySearch(arr, n, key);
        end = clock();
        double binaryTime =
            (double)(end - start) / CLOCKS_PER_SEC;
        printf("Size: %d\n", n);
        printf("Linear Search Time: %.8f seconds\n", linearTime);
        printf("Binary Search Time: %.8f seconds\n\n", binaryTime);
        free(arr);
    }

    return 0;
}
